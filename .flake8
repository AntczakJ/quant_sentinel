[flake8]
max-line-length = 120
exclude = .git, __pycache__, venv, .venv, build, dist, *.egg-info, tests/*, node_modules
ignore = E203, E266, E501, W503, F403, F401

[pycodestyle]
max-line-length = 120
indent-size = 4

[isort]
profile = black
line_length = 120
skip_gitignore = True
multi_line_mode = 3
include_trailing_comma = True
force_grid_wrap = 0
use_parentheses = True
ensure_newline_before_comments = True

