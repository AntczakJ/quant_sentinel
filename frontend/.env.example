# Quant Sentinel frontend env — copy to .env.local for development.
# .env.local is gitignored; do NOT commit your real secret.

# API base URL. Default uses Vite proxy to backend at http://127.0.0.1:8000.
# In production, point at the deployed backend.
# VITE_API_URL=/api

# 2026-05-04: backend protects POST/PUT/DELETE under /api/* with X-API-Key.
# Must match API_SECRET_KEY in your backend .env.
# Without this, all write operations (scanner pause, grid apply, portfolio
# updates) return 401 Unauthorized.
VITE_API_SECRET_KEY=your_api_secret_key_here
