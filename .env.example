# ================================================================
#  .env.example — wzorzec konfiguracji dla quant_sentinel
#
#  INSTRUKCJA:
#    1. Skopiuj ten plik: cp .env.example .env
#    2. Uzupełnij swoje klucze API poniżej
#    3. NIGDY nie commituj .env do git!
# ================================================================

# ── TELEGRAM ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── OPENAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── TWELVE DATA (dane rynkowe) ──────────────────────────────────
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# ── BAZA DANYCH ─────────────────────────────────────────────────
# Primary: lokalny SQLite (zawsze aktywny, szybki odczyt + dane treningowe)
DATABASE_URL=data/sentinel.db

# Secondary: Turso cloud sync (opcjonalny — trades, signals, portfolio)
# Jeśli ustawione, dane production sync-ują się do chmury.
# Dane treningowe (ml_predictions, feature cache) zostają tylko lokalnie.
# TURSO_URL=libsql://your-db.turso.io
# TURSO_TOKEN=your_turso_auth_token_here

# ── DANE MAKRO ──────────────────────────────────────────────────
# FRED (darmowy: https://fred.stlouisfed.org/docs/api/api_key.html)
# FRED_API_KEY=your_fred_api_key_here

# Finnhub (darmowy: https://finnhub.io/register)
# FINNHUB_API_KEY=your_finnhub_key_here

# ── INNE (opcjonalne) ───────────────────────────────────────────
# NEWS_API_KEY=your_news_api_key_here
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── API SECURITY ────────────────────────────────────────────────
# API key for write endpoints (POST/PUT/DELETE). Leave empty to disable auth.
# API_SECRET_KEY=your_secret_api_key_here

# ── ML Feature Flags ────────────────────────────────────────────
# ENABLE_ML=True
# ENABLE_RL=True
# ENABLE_BAYES=False
# ENABLE_ADVANCED_INDICATORS=True
# ENABLE_PATTERNS=True

# ── TRYB DZIAŁANIA ──────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── PERFORMANCE OBSERVATION ────────────────────────────────────
# Threshold above which an HTTP request is logged as "SLOW" with method,
# path, status, and elapsed ms. Default 500. Tune lower (e.g. 200) when
# hunting unexpected latency, higher (e.g. 1500) to silence routine slow
# endpoints like /api/grid/preview.
# SLOW_REQUEST_MS=500

# ── ERROR TRACKING (Sentry) ─────────────────────────────────────
# Soft-enabled when SENTRY_DSN is set. Captures uncaught exceptions
# (FastAPI / httpx / asyncio), slow transactions, and (optional) cron
# heartbeats from the BG scanner. Free tier covers 5 k events/month —
# more than enough for a single trader.
# SENTRY_DSN=
# SENTRY_ENV=production
# SENTRY_TRACES_RATE=0.05      # 0–1, fraction of transactions to sample
# SENTRY_PROFILES_RATE=0.0     # leave 0 unless debugging perf hot spots

# ── OBSERVABILITY (Logfire / OpenTelemetry) ────────────────────
# Pydantic-team OTEL platform. When set, the API exports traces for:
#   - every FastAPI request (method, path, status, duration)
#   - every httpx outbound call (TwelveData, AlphaVantage, FRED, etc.)
#   - every sqlite3 query (param-redacted)
#   - background scanner cycle: scanner.prefetch_tfs + scanner.cascade_mtf
# Without a token Logfire is a soft no-op (zero network, near-zero CPU).
# Free tier is 10M spans/month — enough for a single trader.
#
# Setup: run `.venv/Scripts/logfire auth` once, then `logfire projects use
# <name>`. The token persists in ~/.logfire/credentials and is auto-loaded.
# Or paste a write-token here directly:
# LOGFIRE_TOKEN=

