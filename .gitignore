# ==============================================================
#  quant_sentinel — .gitignore
#  Cel: po `git pull` na nowym urządzeniu masz od razu:
#    - kod źródłowy (src/, api/, frontend/src/)
#    - wytrenowane modele (models/)
#    - bazę danych (data/sentinel.db)
#    - skrypty treningowe (train_all.py, train_rl.py)
#    - requirements.txt
#  NIE ma: .env (sekrety), .venv (środowisko), __pycache__, buildy
# ==============================================================

# ── SEKRETY I KONFIGURACJA LOKALNA ────────────────────────────
.env
.env.*
!.env.example
.env.local
.env.*.local
*.key
*.pem
secrets/
credentials/

# ── PYTHON — ŚRODOWISKO WIRTUALNE ─────────────────────────────
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ── PYTHON — CACHE I ARTEFAKTY ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.dmypy.json
.ruff_cache/
*.egg-info/
*.egg
MANIFEST
.eggs/

# ── PYTHON — DYSTRYBUCJA / BUILD ──────────────────────────────
build/
dist/
*.whl
*.tar.gz

# ── LOGI I PLIKI RUNTIME ──────────────────────────────────────
logs/
*.log
*.log.*

# ── CACHE APLIKACJI (nie modele — te są potrzebne) ───────────
cache/
*.cache
.cache/
persistent_cache/

# ── BAZA DANYCH — KOPIE ZAPASOWE ──────────────────────────────
# data/sentinel.db        → ŚLEDZONE w git (potrzebne do treningu)
# data/test_sentinel.db   → ŚLEDZONE (testy)
data/sentinel_backup_*.db
data/backups/
data/*.db.bak
data/*.db-wal
data/*.db-shm
data/cot_cache.pkl
data/fred_cache.pkl
data/sentiment_cache.pkl
data/gpr_cache.pkl
data/event_reactions_cache.pkl
data/news_faiss_index.pkl

# ── MODELE ML — WSZYSTKIE ŚLEDZONE ────────────────────────────
# models/lstm.h5, lstm.keras, lstm_scaler.pkl,
# rl_agent.keras, rl_agent.keras.params, xgb.pkl
# → ŚLEDZONE (potrzebne do kontynuacji treningu)
# Odkomentuj poniższe TYLKO jeśli modele są za duże dla git:
# models/*.h5
# models/*.keras
# models/*.pkl
# models/*.params
# models/*.joblib
# models/*.pt
# models/*.pth

# ── FRONTEND — NODE MODULES I BUILD ──────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.*.local
frontend/tsconfig.tsbuildinfo

# ── IDE I EDYTORY ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
*.sublime-project
*.sublime-workspace
.vim/

# ── SYSTEM OPERACYJNY ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── MENEDŻERY PAKIETÓW ────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── PLIKI CACHE RUNTIME (regenerowane automatycznie) ──────────
models/calibration_params.pkl
models/test/
models/decompose_scaler.pkl
# Backtest DB — scratch file, regenerated per run. Never commit.
data/backtest.db
data/backtest.db-journal
data/backtest.db-wal
data/backtest.db-shm
# Backtest yfinance cache — regenerated, may be large (parquet files)
data/_backtest_cache/

# Optuna sweeps — SQLite studies + data caches + live heartbeats.
# All regenerable; do not commit.
data/optuna_rl.db*
data/optuna_lstm.db*
data/_sweep_cache/
data/_lstm_sweep_cache/
data/sweep_heartbeat.json
data/lstm_sweep_heartbeat.json

# Ephemeral sweep winner + pre-promote backup model files.
# The ones we care about ARE the production models/*.keras; these are
# scratch artefacts for rollback/inspection only.
models/*_sweep_winner.keras
models/*_sweep_winner.onnx
models/*_sweep_winner*.pkl
models/*_sweep_winner.keras.params
models/*.pre_*_promote.keras
models/*.pre_*_promote.onnx
models/*.pre_*_promote.keras.params
models/*_scaler.pre_*_promote.pkl

# Autonomous overnight session artefacts.
logs/autonomous_*.log
logs/autonomous_*.md
logs/autonomous_*.txt

# Walk-forward grid backtest reports (per-cell JSONs can be large).
reports/wf_grid_*/

# Archived / orphaned model artifacts — experiments kept locally for
# rollback but not needed in git.
models/_archive/
models/_backup_*/

# ── EKSPERYMENTALNE BACKUPY MODELI ────────────────────────────
# Lokalne kopie zostawiane przy eksperymentach (np. retrain z innym setupem).
# Mogą być duże, nie są potrzebne w repo.
models/*_v[0-9]*.keras
models/*_v[0-9]*.keras.params
models/*_candidate.keras
models/*_candidate.keras.params
models/*_backup.keras
models/*_backup.keras.params
.coverage
htmlcov/

# ── CLAUDE CODE (osobne per-urządzenie) ──────────────────────
.claude/

# ── RAPORTY TYMCZASOWE ────────────────────────────────────────
*.tmp
*.bak
*.orig
*.temp
.~*
docs/reports/
docs/analysis/
analysis_output/
reports/
*.csv.backup

# ── PLIKI TYMCZASOWE JUPYTER ──────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── UPEWNIJ SIĘ ŻE TE PLIKI SĄ ŚLEDZONE ─────────────────────
!.gitkeep
!models/.gitkeep
!data/.gitkeep
!logs/.gitkeep
!cache/.gitkeep
!requirements.txt
!train_all.py
!train_rl.py
